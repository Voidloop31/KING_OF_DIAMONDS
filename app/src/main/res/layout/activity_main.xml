<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#1a0a2e">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <!--  WELCOME SCREEN  -->
        <LinearLayout android:id="@+id/welcomeLayout" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingTop="60dp" android:visibility="visible">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="♦" android:textSize="80sp" android:textColor="#e63946" android:gravity="center" android:layout_marginBottom="10dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KING OF DIAMONDS" android:textSize="28sp" android:textColor="#ffffff" android:textStyle="bold" android:gravity="center" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Keynesian Beauty Contest" android:textSize="14sp" android:textColor="#a0a0c0" android:gravity="center" android:layout_marginBottom="40dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="The visa lasers are armed. The King of Diamonds demands an audience." android:textSize="13sp" android:textColor="#c0b8d8" android:gravity="center" android:lineSpacingExtra="4dp" android:padding="16dp" android:background="#2d1a4a" android:layout_marginBottom="16dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📋 HOW TO PLAY\n\n• You and a Bot both pick a number (0–100)\n• The average of both numbers is calculated\n• That average × 0.8 = the Spider Number\n• Whoever is closest to the Spider Number wins the round!\n• Best of 5 rounds wins the game" android:textSize="13sp" android:textColor="#d0c8e8" android:padding="16dp" android:lineSpacingExtra="5dp" android:background="#16213e" android:layout_marginBottom="40dp"/>
            <Button android:id="@+id/startButton" android:layout_width="match_parent" android:layout_height="56dp" android:text="ENTER THE ARENA" android:textSize="16sp" android:textStyle="bold" android:textColor="#ffffff" android:backgroundTint="#e63946" android:letterSpacing="0.05"/>
        </LinearLayout>
        <!--  GAME SCREEN  -->
        <LinearLayout android:id="@+id/gameLayout" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingTop="40dp" android:visibility="gone">
            <TextView android:id="@+id/roundText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Round 1 of 5" android:textSize="18sp" android:textColor="#a0a0c0" android:gravity="center" android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/scoreText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="You: 0 | Bot: 0" android:textSize="22sp" android:textColor="#ffffff" android:textStyle="bold" android:gravity="center" android:layout_marginBottom="40dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🕷️" android:textSize="60sp" android:gravity="center" android:layout_gravity="center" android:layout_marginBottom="20dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Choose your number wisely.\nThe spider is watching." android:textSize="14sp" android:textColor="#a0a0c0" android:gravity="center" android:lineSpacingExtra="4dp" android:layout_marginBottom="30dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Enter a number (0 to 100):" android:textSize="15sp" android:textColor="#d0c8e8" android:layout_marginBottom="10dp"/>
            <EditText android:id="@+id/numberInput" android:layout_width="match_parent" android:layout_height="56dp" android:inputType="number" android:hint="0 - 100" android:textColor="#ffffff" android:textColorHint="#606080" android:textSize="18sp" android:gravity="center" android:background="#2d1a4a" android:padding="12dp" android:layout_marginBottom="20dp"/>
            <Button android:id="@+id/submitButton" android:layout_width="match_parent" android:layout_height="56dp" android:text="LOCK IN NUMBER" android:textSize="16sp" android:textStyle="bold" android:textColor="#ffffff" android:backgroundTint="#e63946"/>
        </LinearLayout>
        <!--  RESULT SCREEN  -->
        <LinearLayout android:id="@+id/resultLayout" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingTop="40dp" android:visibility="gone">
            <TextView android:id="@+id/resultTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Round Result" android:textSize="26sp" android:textColor="#ffffff" android:textStyle="bold" android:gravity="center" android:layout_marginBottom="30dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#16213e" android:padding="20dp" android:layout_marginBottom="16dp">
                <TextView android:id="@+id/yourNumberText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Your number: -" android:textSize="16sp" android:textColor="#88d8b0" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/botNumberText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Bot's number: -" android:textSize="16sp" android:textColor="#ff9f43" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/avgText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Average: -" android:textSize="16sp" android:textColor="#d0c8e8" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/spiderText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Spider Number: -" android:textSize="16sp" android:textColor="#e63946" android:textStyle="bold"/>
            </LinearLayout>
            <TextView android:id="@+id/winnerText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="-" android:textSize="14sp" android:textColor="#a0a0c0" android:gravity="center" android:layout_marginBottom="12dp"/>
            <TextView android:id="@+id/roundScoreText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Score → You: 0 | Bot: 0" android:textSize="18sp" android:textColor="#ffffff" android:textStyle="bold" android:gravity="center" android:layout_marginBottom="30dp"/>
            <Button android:id="@+id/nextButton" android:layout_width="match_parent" android:layout_height="56dp" android:text="Next Round" android:textSize="16sp" android:textStyle="bold" android:textColor="#ffffff" android:backgroundTint="#e63946"/>
        </LinearLayout>
        <!--  FINAL SCREEN  -->
        <LinearLayout android:id="@+id/finalLayout" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingTop="60dp" android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="♦" android:textSize="80sp" android:textColor="#e63946" android:gravity="center" android:layout_marginBottom="20dp"/>
            <TextView android:id="@+id/finalTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="GAME OVER" android:textSize="28sp" android:textColor="#ffffff" android:textStyle="bold" android:gravity="center" android:layout_marginBottom="20dp"/>
            <TextView android:id="@+id/finalScoreText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Final Score\nYou: 0 | Bot: 0" android:textSize="22sp" android:textColor="#e63946" android:textStyle="bold" android:gravity="center" android:layout_marginBottom="20dp"/>
            <TextView android:id="@+id/finalMessageText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="-" android:textSize="14sp" android:textColor="#a0a0c0" android:gravity="center" android:layout_marginBottom="40dp"/>
            <Button android:id="@+id/playAgainButton" android:layout_width="match_parent" android:layout_height="56dp" android:text="PLAY AGAIN" android:textSize="16sp" android:textStyle="bold" android:textColor="#ffffff" android:backgroundTint="#e63946"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>